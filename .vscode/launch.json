{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Live Server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "live-server",
        ".",
        "--port=5500",
        "--open=index.html",
        "--no-browser=false"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
